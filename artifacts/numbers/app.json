{
  "expo": {
    "name": "Number - Never Guess Again",
    "slug": "numberneverguessagain",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "numberneverguessagain",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0A16"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.numberneverguessagain.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "NUMBER uses your photo library to allow you to upload competition schedules and scoring sheets so your team can access them in the app.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "backgroundColor": "#0E0A16",
      "package": "com.numberneverguessagain.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "exclude": [
                "META-INF/versions/9/OSGI-INF/MANIFEST.MF"
              ]
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "e8069bac-d5bf-46ca-ab57-f212395c9b32"
      }
    }
  }
}